{
  "name": "fou-du-roi-hd",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepare:desktop": "mkdir -p dist-electron && cp electron/package.json dist-electron/package.json",
    "prepare:icons": "node scripts/generate-app-icon.mjs",
    "desktop": "electron .",
    "dev:desktop": "npm run prepare:desktop && concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://127.0.0.1:5173 dist-electron/main.js dist-electron/package.json && ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .\"",
    "build:desktop": "npm run build && tsc -p tsconfig.electron.json && npm run prepare:desktop",
    "preview:desktop": "npm run build:desktop && electron .",
    "pack:desktop": "npm run prepare:icons && npm run build:desktop && electron-builder --dir",
    "dist:mac": "npm run prepare:icons && npm run build:desktop && electron-builder --mac dmg",
    "dist:win": "npm run prepare:icons && npm run build:desktop && electron-builder --win nsis"
  },
  "dependencies": {
    "phaser": "^3.90.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.foudroi.desktop",
    "productName": "Fou du Roi HD",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.games",
      "icon": "public/icons/hero-app-icon.png"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
